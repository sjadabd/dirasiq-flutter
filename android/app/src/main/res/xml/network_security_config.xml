<?xml version="1.0" encoding="utf-8"?>
<!--
  Allow cleartext HTTP only for the Android emulator's host loopback
  (10.0.2.2 == localhost on the developer machine). Everything else stays
  HTTPS-only (production api.mulhimiq.com). 127.0.0.1 is included for
  iOS-simulator parity but is meaningless on a real Android device.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
